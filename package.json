    "next-themes": "^0.4.6",
    "react-icons": "^5.6.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@devlinks/config": "workspace:*",
    "@types/node": "^22.13.14",
    "drizzle-kit": "^0.31.10",
